<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Il Ciliegio – Scan & Enjoy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
  @page {
    size: A5;
    margin: 0;
  }
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  body {
    width: 148mm;
    height: 210mm;
    overflow: hidden;
    background: #0d0a06;
    font-family: 'Lato', sans-serif;
    position: relative;
  }

  .bg-photo {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=600&q=80');
    background-size: cover;
    background-position: center 30%;
    filter: brightness(0.32) saturate(0.8);
    z-index: 0;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10,7,2,0.55) 0%,
      rgba(139,100,20,0.10) 40%,
      rgba(10,7,2,0.50) 65%,
      rgba(10,7,2,0.95) 100%
    );
    z-index: 1;
  }

  .frame {
    position: absolute;
    inset: 5mm;
    border: 0.4mm solid rgba(184,150,30,0.5);
    z-index: 2;
    pointer-events: none;
  }
  .frame::before {
    content: '';
    position: absolute;
    inset: 2mm;
    border: 0.15mm solid rgba(184,150,30,0.25);
  }

  .corner {
    position: absolute;
    width: 6mm;
    height: 6mm;
    border-color: #b8961e;
    border-style: solid;
    z-index: 3;
  }
  .corner.tl { top: 4mm; left: 4mm; border-width: 0.6mm 0 0 0.6mm; }
  .corner.tr { top: 4mm; right: 4mm; border-width: 0.6mm 0.6mm 0 0; }
  .corner.bl { bottom: 4mm; left: 4mm; border-width: 0 0 0.6mm 0.6mm; }
  .corner.br { bottom: 4mm; right: 4mm; border-width: 0 0.6mm 0.6mm 0; }

  .content {
    position: relative;
    z-index: 4;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 9mm 10mm 7mm;
    gap: 0;
  }

  /* Logo – unchanged size */
  .logo-wrap {
    width: 38mm;
    margin-top: 0;
    margin-bottom: 2mm;
    flex-shrink: 0;
  }
  .logo-wrap img {
    width: 100%;
    filter: drop-shadow(0 0 4px rgba(184,150,30,0.4));
  }

  /* Family tagline just below logo */
  .family-tag {
    font-family: 'Cinzel', serif;
    font-size: 7pt;
    letter-spacing: 0.22em;
    color: #b8961e;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 2.5mm;
  }

  .divider {
    width: 34mm;
    height: 0.2mm;
    background: linear-gradient(90deg, transparent, #b8961e, transparent);
    margin: 0 auto 3mm;
    flex-shrink: 0;
  }

  /* Headline – bigger */
  .headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26pt;
    font-weight: 300;
    color: #f5efe0;
    text-align: center;
    line-height: 1.12;
    letter-spacing: 0.01em;
    margin-bottom: 8mm;
    flex-shrink: 0;
  }
  .headline em {
    font-style: italic;
    color: #d4aa45;
  }

  /* Subhead – bigger */
  .subhead {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 12pt;
    color: rgba(245,239,224,0.72);
    text-align: center;
    margin-bottom: 8mm;
    line-height: 1.4;
    max-width: 116mm;
    flex-shrink: 0;
  }

  /* QR code – centered, larger */
  .qr-wrap {
    flex-shrink: 0;
    width: 36mm;
    height: 36mm;
    padding: 2.5mm;
    background: #fff;
    border-radius: 2.5mm;
    box-shadow: 0 0 16px rgba(184,150,30,0.35);
    margin-bottom: 8mm;
  }
  .qr-wrap img {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* 3 benefits – centered, Cormorant Garamond italic like subhead */
  .benefits {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2mm;
    margin-bottom: 5.5mm;
    width: 100%;
    max-width: 120mm;
    flex-shrink: 0;
  }
  .benefit-item {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 2mm;
    text-align: center;
  }
  .benefit-icon {
    color: #b8961e;
    font-size: 9pt;
    flex-shrink: 0;
    margin-top: 1.5pt;
  }
  .benefit-text {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 10pt;
    color: #d4aa45;
    line-height: 1.35;
  }

  /* CTA bar – bigger */
  .cta-bar {
    background: rgba(184,150,30,0.15);
    border: 0.3mm solid rgba(184,150,30,0.42);
    border-radius: 2mm;
    padding: 3mm 7mm;
    text-align: center;
    margin-bottom: 2mm;
    width: 100%;
    max-width: 124mm;
    flex-shrink: 0;
  }
  .cta-bar .step {
    font-family: 'Cinzel', serif;
    font-size: 7.5pt;
    letter-spacing: 0.2em;
    color: #b8961e;
    text-transform: uppercase;
    margin-bottom: 1.5mm;
  }
  .cta-bar .instruction {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13pt;
    color: #f5efe0;
    line-height: 1.3;
  }

  /* Dividers around CTA bar */
  .divider-footer {
    width: 40mm;
    height: 0.3mm;
    background: linear-gradient(90deg, transparent, #b8961e, transparent);
    flex-shrink: 0;
    margin: 0 auto;
  }
  .divider-footer.top  { margin-bottom: 2.5mm; }
  .divider-footer.bot  { margin-top: 0; }

  /* Footer – MOST IMPORTANT – significantly larger */
  .bottom-strip {
    text-align: center;
    flex-shrink: 0;
    padding-top: 6mm;
  }
  .website {
    font-family: 'Cinzel', serif;
    font-size: 8pt;
    letter-spacing: 0.22em;
    color: rgba(184,150,30,0.85);
    text-transform: uppercase;
    line-height: 1.6;
    display: block;
  }
</style>
</head>
<body>
  <div class="bg-photo"></div>
  <div class="overlay"></div>
  <div class="frame"></div>
  <div class="corner tl"></div>
  <div class="corner tr"></div>
  <div class="corner bl"></div>
  <div class="corner br"></div>

  <div class="content">

    <div class="logo-wrap">
      <img src="data:image/png;base64," alt="Il Ciliegio">
    </div>

    <div class="family-tag">Pattaro Family &nbsp;·&nbsp; Winegrowers in Tuscany since 1952</div>
    <div class="divider"></div>

    <div class="headline">
      The taste of <em>Toscana</em><br>
      delivered to your door
    </div>

    <div class="subhead">
      Scan the code below and discover our exclusive Online Shop App.<br>
      Just one click and the best of our estate arrives at your home.
    </div>

    <div class="qr-wrap">
      <img src="data:image/png;base64," alt="QR Code Il Ciliegio Shop">
    </div>

    <div class="benefits">
      <div class="benefit-item">
        <span class="benefit-icon">✦</span>
        <span class="benefit-text">Reserved Only For Those Who Scan — Special Offers You Won't Find Anywhere Else</span>
      </div>
      <div class="benefit-item">
        <span class="benefit-icon">✦</span>
        <span class="benefit-text">Authentic, Artisan Products Straight From Our Toscana Fields To Your Table</span>
      </div>
      <div class="benefit-item">
        <span class="benefit-icon">✦</span>
        <span class="benefit-text">Enjoy Il Ciliegio Wherever You Are, Any Time You Wish</span>
      </div>
    </div>

    <div class="divider-footer top"></div>

    <div class="cta-bar">
      <div class="step">Three seconds. That's all it takes.</div>
      <div class="instruction">Open your camera &nbsp;·&nbsp; Point at the QR code &nbsp;·&nbsp; Start shopping</div>
    </div>

    <div class="divider-footer bot"></div>

    <div class="bottom-strip">
      <span class="website">www.ilciliegio.com</span>
    </div>

  </div>
</body>
</html>